# ── POSTGRES ─────────────────────────────────────────────────────
POSTGRES_USER=quizapp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=quizdb
 
# ── JWT ──────────────────────────────────────────────────────────
# Must be IDENTICAL in every service — min 32 characters
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET_KEY
 
# ── MAIL ─────────────────────────────────────────────────────────
# For Gmail: create an App Password at
# Google Account → Security → 2-Step Verification → App Passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
 
# ── SERVICE PORTS (used inside Docker network) ───────────────────
AUTH_SERVICE_PORT=8081
QUIZ_SERVICE_PORT=8082
QUESTION_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
GATEWAY_PORT=8080